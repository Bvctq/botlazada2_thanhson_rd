# --- Bat buoc ---

# Token bot lay tu @BotFather tren Telegram (vd: 123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TELEGRAM_BOT_TOKEN=

# 1 chuoi bi mat tu dat (chu+so, cang dai cang tot) - dung de bao ve webhook.
# Co the tu tao bang: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# Master link affiliate cua ban, xem trong o "Master link" o trang tao
# affiliate shortlink cua Lazada (vd: https://c.lazada.vn/t/c.YParqP)
LAZADA_MASTER_LINK=

# Danh sach Telegram user id (dang so) duoc phep dung bot, cach nhau boi dau
# phay. Lay user id bang cach nhan tin cho @userinfobot tren Telegram.
# vd: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# --- Tuy chon ---

# appKey dung trong API cua Lazada - hau nhu khong thay doi, de mac dinh la duoc
LAZADA_APP_KEY=24677475

# Chi dien neu ban muon dung cookie that (da dang nhap) thay vi che do tu
# dong an danh - copy nguyen phan sau "-b " trong curl (xem README.md).
# Co the bo trong, bot se tu bootstrap token an danh.
LAZADA_COOKIE=

# Khoang cach (giay) giua cac lan goi API khi xu ly nhieu link trong 1 tin
# nhan, tranh goi qua nhanh lien tuc
CALL_DELAY_SECONDS=0.6

# Render tu dong dien bien nay - KHONG can tu dat khi deploy tren Render.
# Chi can dat thu cong neu chay o moi truong khac va muon bot tu dang ky webhook.
# RENDER_EXTERNAL_URL=https://ten-service-cua-ban.onrender.com
